{
  "$schema": "https://raw.githubusercontent.com/nicolas-chaulet/tauri-v2-schemas/main/schema.json",
  "productName": "fastboot-flasher-gui",
  "version": "0.1.0",
  "identifier": "com.fastboot-flasher.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Fastboot Flasher",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "nsis"],
    "icon": [
      "icons/256x256.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    }
  },
  "plugins": {

    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": false
    }
  }
}
